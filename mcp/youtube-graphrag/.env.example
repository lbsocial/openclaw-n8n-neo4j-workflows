# Copy this file to .env for local testing only.
# Do not commit real credentials.

# Neo4j AuraDB or self-managed Neo4j
NEO4J_URI=neo4j+s://YOUR_AURA_ID.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# Choose the embedding provider used by the MCP server.
# The tutorial default matches the n8n ingestion workflow: Gemini, 768 dimensions.
EMBEDDING_PROVIDER=gemini

# OpenAI embedding configuration
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini embedding configuration
# This is useful if you want to keep the stack closer to Google Cloud / Gemini.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

# Neo4j graph/vector configuration.
# These defaults match the OpenClaw + n8n + YouTube metadata tutorial graph:
# (:Channel)-[:PUBLISHED]->(:Video)-[:HAS_TOPIC]->(:Topic)
YOUTUBE_VIDEO_VECTOR_INDEX=video_embeddings
YOUTUBE_VIDEO_LABEL=Video
YOUTUBE_CHANNEL_LABEL=Channel
YOUTUBE_TOPIC_LABEL=Topic
YOUTUBE_CHANNEL_TO_VIDEO_REL=PUBLISHED
YOUTUBE_VIDEO_TO_TOPIC_REL=HAS_TOPIC
YOUTUBE_VIDEO_EMBEDDING_PROPERTY=embedding
YOUTUBE_VIDEO_ID_PROPERTY=video_id
YOUTUBE_VIDEO_TITLE_PROPERTY=title
YOUTUBE_VIDEO_URL_PROPERTY=url
YOUTUBE_VIDEO_DOCUMENT_TEXT_PROPERTY=document_text
YOUTUBE_VIDEO_PUBLISHED_AT_PROPERTY=published_at
YOUTUBE_CHANNEL_TITLE_PROPERTY=channel_title
YOUTUBE_TOPIC_NAME_PROPERTY=name

# Limits how many nodes/relationships are sampled by get_neo4j_schema_and_indexes.
NEO4J_SCHEMA_SAMPLE_SIZE=100
